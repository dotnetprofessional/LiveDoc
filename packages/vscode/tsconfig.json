{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2022",
        "outDir": "out",
        "lib": [
            "ES2022",
            "dom"
        ],
        "sourceMap": true,
        "rootDir": "src",
        "jsx": "react-jsx",
        "strict": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        ".vscode-test",
        "src/reporter/index.tsx",
        "src/reporter/components",
        "src/test"
    ]
}