{
    "name": "@livedoc/vscode",
    "displayName": "livedoc",
    "description": "Tools and snippets for working with LiveDoc BDD testing (Vitest)",
    "version": "0.0.1",
    "publisher": "dotnetprofessional",
    "icon": "images/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/dotnetprofessional/LiveDoc.git"
    },
    "engines": {
        "vscode": "^1.25.1"
    },
    "categories": [
        "Snippets"
    ],
    "keywords": [
        "bdd",
        "gherkin",
        "cucumber",
        "javascript",
        "testing"
    ],
    "activationEvents": [
        "onLanguage:typescript",
        "onLanguage:typescriptreact",
        "onLanguage:javascriptreact",
        "onLanguage:javascript",
        "onLanguage:plaintext",
        "onView:livedoc"
    ],
    "main": "./out/extension",
    "contributes": {
        "commands": [
            {
                "command": "extension.formatDataTables",
                "title": "LiveDoc: Format Data Tables"
            },
            {
                "command": "webview.start",
                "title": "LiveDoc: Reporter"
            }
        ],
        "snippets": [
            {
                "language": "typescript",
                "path": "./snippets/livedoc.json"
            },
            {
                "language": "typescriptreact",
                "path": "./snippets/livedoc.json"
            },
            {
                "language": "javascript",
                "path": "./snippets/livedoc.json"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "livedoc-explorer",
                    "title": "livedoc explorer",
                    "icon": "images/activity-bar-icon.svg"
                }
            ]
        },
        "views": {
            "livedoc-explorer": [
                {
                    "id": "livedoc",
                    "name": "livedoc explorer"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "pnpm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "vsce package",
        "test": "pnpm run compile",
        "link-livedoc": "node scripts/link-livedoc.js"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.10",
        "@types/node": "^20.19.26",
        "@types/react": "^18.3.27",
        "@types/react-dom": "^18.3.7",
        "@types/vscode": "^1.106.1",
        "fs-extra": "^11.3.2",
        "typescript": "~5.5.4"
    },
    "dependencies": {
        "@livedoc/vitest": "workspace:*",
        "aphrodite": "^2.4.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    }
}
