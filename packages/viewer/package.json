{
  "name": "@livedoc/viewer",
  "version": "1.0.0",
  "description": "LiveDoc BDD Test Results Viewer - Real-time test visualization",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "livedoc-viewer": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "dev:all": "start cmd /c \"npm run dev\" && npm run dev:client",
    "build": "npm run build:client && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "vite build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.client.json && tsc --noEmit -p tsconfig.server.json"
  },
  "dependencies": {
    "@livedoc/server": "workspace:*",
    "commander": "^12.1.0",
    "open": "^10.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^22.19.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "livedoc",
    "bdd",
    "testing",
    "vitest",
    "xunit",
    "reporter",
    "viewer"
  ],
  "author": "",
  "license": "MIT"
}
