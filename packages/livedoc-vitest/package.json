{
  "name": "livedoc-vitest",
  "version": "1.0.0",
  "author": "Garry McGlennon",
  "description": "BDD extensions for Vitest that support LiveDoc reporting with Gherkin syntax.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotnetprofessional/LiveDoc.git"
  },
  "homepage": "https://github.com/dotnetprofessional/LiveDoc/blob/master/packages/livedoc-vitest#readme",
  "bugs": {
    "url": "https://github.com/dotnetprofessional/LiveDoc/issues"
  },
  "type": "module",
  "main": "./dist/app/index.js",
  "module": "./dist/app/index.js",
  "types": "./dist/app/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app/index.d.ts",
      "import": "./dist/app/index.js"
    },
    "./reporter": {
      "types": "./dist/app/reporter/index.d.ts",
      "import": "./dist/app/reporter/index.js"
    }
  },
  "keywords": [
    "livedoc",
    "vitest",
    "bdd",
    "gherkin",
    "cucumber",
    "javascript",
    "typescript",
    "testing",
    "tests"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:summary": "vitest run --config vitest.config.summary.ts",
    "test:list": "vitest run --config vitest.config.list.ts",
    "test:spec": "vitest run",
    "test:silent": "vitest run --config vitest.config.silent.ts",
    "test:file": "vitest run --config vitest.config.file.ts",
    "test:json": "vitest run --config vitest.config.json.ts",
    "test:viewer": "vitest run --config vitest.config.viewer.ts",
    "test:coverage": "vitest run --coverage",
    "compile": "rimraf dist && tsc -p tsconfig.json",
    "build": "npm run compile",
    "watch": "tsc --watch -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.10.0",
    "@types/wordwrap": "^1.0.3",
    "@vitest/ui": "^4.0.14",
    "chai": "^6.2.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3",
    "vitest": "^4.0.14"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "dependencies": {
    "@types/diff": "^7.0.2",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.3",
    "diff": "^5.1.0",
    "fs-extra": "^11.3.2",
    "wordwrap": "^1.0.0"
  }
}
