{
  "name": "@swedevtools/livedoc-schema",
  "version": "1.2.0",
  "description": "Canonical vNext data model for LiveDoc",
  "author": "Garry McGlennon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotnetprofessional/LiveDoc.git",
    "directory": "packages/schema"
  },
  "homepage": "https://github.com/dotnetprofessional/LiveDoc/tree/master/packages/schema#readme",
  "bugs": {
    "url": "https://github.com/dotnetprofessional/LiveDoc/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "rimraf": "^6.1.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ]
}
