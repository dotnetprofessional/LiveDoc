{
  "name": "@livedoc/server",
  "version": "1.0.0",
  "description": "LiveDoc Server - Shared server infrastructure for LiveDoc ecosystem",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "bin": {
    "livedoc-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.7",
    "commander": "^12.1.0",
    "hono": "^4.10.7",
    "open": "^10.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@livedoc/vitest": "workspace:*",
    "@types/node": "^22.19.2",
    "@types/ws": "^8.18.1",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "livedoc",
    "bdd",
    "testing",
    "server",
    "websocket"
  ],
  "author": "",
  "license": "MIT"
}
