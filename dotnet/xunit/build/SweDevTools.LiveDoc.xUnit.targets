<Project>
  <!--
    One-time build warning prompting developers to install the LiveDoc AI skill.
    Suppressed once .livedoc-skill-installed sentinel file exists in the project root.
  -->
  <Target Name="LiveDocSkillInstallReminder" BeforeTargets="BeforeBuild"
          Condition="!Exists('$(MSBuildProjectDirectory)\.livedoc-skill-installed')">
    <Warning Text="[LiveDoc] AI coding skills are available for this project. Run 'dotnet livedoc install-skill' to set up test-authoring guidance for your AI tool (Copilot, Claude Code, Cursor, etc.). See: https://github.com/dotnetprofessional/LiveDoc" />
  </Target>
</Project>
