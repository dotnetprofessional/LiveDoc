<Project>
  <!--
    LiveDoc test logger: register the logger DLL so VSTest discovers it.
    Usage: dotnet test ~~logger LiveDoc
  -->
  <PropertyGroup>
    <_LiveDocLoggerDir>$(MSBuildThisFileDirectory)net8.0\</_LiveDocLoggerDir>
  </PropertyGroup>
  <ItemGroup>
    <VSTestTestAdaptersPaths Include="$(_LiveDocLoggerDir)" />
  </ItemGroup>

  <!--
    LiveDoc AI Skill Installer.
    Invoked explicitly: dotnet msbuild -t:LiveDoc
    NOT run during normal builds.
  -->
  <PropertyGroup>
    <LiveDocToolsDir>$(MSBuildThisFileDirectory)..\tools\</LiveDocToolsDir>
  </PropertyGroup>

  <Target Name="LiveDoc">
    <!-- Windows -->
    <Exec Condition="$([MSBuild]::IsOSPlatform('Windows')) And '$(LiveDocTool)' == ''"
          Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(LiveDocToolsDir)livedoc-setup.ps1&quot;"
          WorkingDirectory="$(MSBuildProjectDirectory)" />
    <Exec Condition="$([MSBuild]::IsOSPlatform('Windows')) And '$(LiveDocTool)' != ''"
          Command="powershell -NoProfile -ExecutionPolicy Bypass -File &quot;$(LiveDocToolsDir)livedoc-setup.ps1&quot; -Tool $(LiveDocTool)"
          WorkingDirectory="$(MSBuildProjectDirectory)" />
    <!-- Mac / Linux -->
    <Exec Condition="!$([MSBuild]::IsOSPlatform('Windows')) And '$(LiveDocTool)' == ''"
          Command="bash &quot;$(LiveDocToolsDir)livedoc-setup.sh&quot;"
          WorkingDirectory="$(MSBuildProjectDirectory)" />
    <Exec Condition="!$([MSBuild]::IsOSPlatform('Windows')) And '$(LiveDocTool)' != ''"
          Command="bash &quot;$(LiveDocToolsDir)livedoc-setup.sh&quot; --tool $(LiveDocTool)"
          WorkingDirectory="$(MSBuildProjectDirectory)" />
  </Target>
</Project>
